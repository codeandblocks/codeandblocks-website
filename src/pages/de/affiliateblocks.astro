---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  {
    q: 'Funktioniert das Plugin mit jedem WordPress-Theme?',
    a: 'Ja. Affiliate Blocks for Amazon ist theme-unabhängig und funktioniert mit jedem modernen WordPress-Theme, das den Gutenberg-Editor unterstützt.',
  },
  {
    q: 'Was passiert nach dem Kauf?',
    a: 'Du erhältst sofort eine E-Mail mit deinem Lizenzschlüssel. Den gibst du einmalig im WordPress-Adminbereich ein — danach sind alle Pro-Features freigeschaltet und du bekommst automatische Updates.',
  },
  {
    q: 'Kann ich die Pro-Version vor dem Kauf testen?',
    a: 'Die Free-Version steht jederzeit kostenlos auf WordPress.org zur Verfügung. Pro-Features kannst du 14 Tage nach dem Kauf testen — bei Nichtgefallen gibt es eine vollständige Rückerstattung.',
  },
  {
    q: 'Was ist der Unterschied zwischen Personal und Professional?',
    a: 'Personal ist für Blogger ohne Amazon-API-Zugang — du pflegst deine Produktbibliothek manuell über die Browser-Extension. Professional ergänzt direkten Amazon-API-Sync, sodass Produkte automatisch ins Dashboard importiert werden. Dazu kommen Slider-Layout, Vergleichstabelle, Bulk-Import, Custom CSS pro Block und bis zu 5 Websites.',
  },
  {
    q: 'Brauche ich die Browser-Extension?',
    a: 'Ja — eine kostenlose Chrome- und Firefox-Extension ist erforderlich, um Produkte in deine Bibliothek zu importieren. Sie funktioniert mit allen Plänen und ist vollständig kostenlos. (Aktuell in Entwicklung.)',
  },
  {
    q: 'Ich bin ein Buy Me a Coffee-Supporter. Bekomme ich auch Pro-Zugang?',
    a: 'Ja! Aktive BMaC-Supporter (2,99€/Monat) bekommen kostenlosen Supporter-Tier-Zugang — das beinhaltet Grid-/Listen-Layout, Kategorien und bis zu 20 Produkte in der Bibliothek. Trage einfach deine BMaC-E-Mail-Adresse in der Plugin-Einstellungsseite ein.',
  },
  {
    q: 'Gibt es laufende Kosten?',
    a: 'Personal ist als monatliches Abo (3,99€/Monat, jederzeit kündbar) oder als einmalige Lifetime-Zahlung (29,99€) erhältlich. Professional ist ein monatliches Abo (9,99€/Monat, jederzeit kündbar). Wer lieber einmalig zahlt und nur Personal-Features benötigt, ist mit dem Lifetime-Plan am besten bedient.',
  },
];
---

<Layout
  title="Affiliate Blocks for Amazon — Schöne Produktboxen für Gutenberg"
  description="Erstelle in Sekunden ansprechende Amazon-Produktboxen direkt im Gutenberg Editor. Kein Shortcode, kein Pagebuilder. Kostenlos starten, Pro ab 3,99€/Monat."
  canonical="/de/affiliateblocks"
  lang="de"
  altHref="/affiliateblocks"
>

<style>
  /* Equal-height cards */
  #pricing-grid { align-items: stretch; }

  /* Billing toggle */
  .billing-toggle {
    display: flex;
    margin: 0 auto 2.5rem;
    width: fit-content;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 50px;
    padding: 4px;
  }
  .billing-btn {
    background: none;
    border: none;
    padding: .45rem 1.4rem;
    border-radius: 50px;
    font-size: .9rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--color-muted);
    transition: all .2s;
    font-family: var(--font);
  }
  .billing-btn.active {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  /* Default: show monthly, hide lifetime */
  .price-lifetime, .desc-lifetime, .cta-lifetime { display: none; }
  .is-hidden { display: none !important; }

  /* Responsive pricing grid */
  #pricing-grid {
    max-width: 900px;
    margin: 0 auto;
    grid-template-columns: repeat(3, 1fr);
  }
  @media (max-width: 700px) {
    #pricing-grid { grid-template-columns: 1fr; }
  }

  /* BMaC strip */
  .bmac-strip {
    margin-top: 2rem;
    background: rgba(245,158,11,.07);
    border: 1px solid rgba(245,158,11,.2);
    border-radius: var(--radius-lg);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .bmac-icon { font-size: 2rem; flex-shrink: 0; }
  .bmac-content { flex: 1; min-width: 200px; }
  .bmac-content strong { color: var(--color-white); display: block; margin-bottom: .25rem; }
  .bmac-content p { color: var(--color-muted); font-size: .9rem; margin: 0; }
</style>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="badge">WordPress Plugin · Kostenlos verfügbar</span>
      <h1>Amazon-Produktboxen,<br/>die <em>wirklich konvertieren.</em></h1>
      <p>
        Erstelle professionelle Produktboxen direkt im Gutenberg Editor —
        ohne Shortcodes, ohne Pagebuilder, ohne Kompromisse.
      </p>
      <div class="hero-actions">
        <a href="#pricing" class="btn btn--primary btn--lg">Pro ab 3,99€/Monat →</a>
        <a
          href="https://wordpress.org/plugins/affiliate-blocks-for-amazon/"
          target="_blank"
          rel="noopener"
          class="btn btn--outline btn--lg"
        >
          Kostenlos testen ↗
        </a>
      </div>
      <p style="margin-top:1.5rem;font-size:.875rem;color:var(--color-muted);">
        ★★★★★ · Aktiv auf 1.000+ Websites
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="section" style="border-top:1px solid var(--color-border);" id="features">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Features</span>
        <h2>Alles, was du brauchst</h2>
        <p>Fokussierte Features für Affiliate-Marketer — ohne unnötigen Overhead.</p>
      </div>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🧱</div>
          <h3>Nativer Gutenberg Block</h3>
          <p>Kein Shortcode, kein Plugin-Overhead. Einfach den Block einfügen und konfigurieren.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎨</div>
          <h3>Mehrere Block-Stile</h3>
          <p>Standard, Kompakt und mehr — wähle den Stil, der zu deiner Website passt.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔗</div>
          <h3>Tracking-ID Integration</h3>
          <p>Deine Amazon-Tracking-ID wird automatisch an alle Links angehängt. Einmal einstellen, fertig.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Schnell & Leichtgewichtig</h3>
          <p>Kein jQuery, kein unnötiges CSS. Das Plugin lädt nur, was wirklich benötigt wird.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Vergleichstabellen-Block</h3>
          <p>Vergleiche mehrere Produkte in einer übersichtlichen Tabelle — ideal für Review-Artikel. <span style="color:var(--color-accent);font-size:.8rem;font-weight:600;">PRO</span></p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔌</div>
          <h3>Browser-Extension</h3>
          <p>Kostenlose Chrome- & Firefox-Extension zum direkten Importieren von Amazon-Produkten — für alle Pläne erforderlich. <span style="color:var(--color-muted);font-size:.8rem;">(Demnächst verfügbar)</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Free vs Pro -->
  <section class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Vergleich</span>
        <h2>Free vs. Pro</h2>
      </div>
      <div class="comparison" style="max-width:760px;margin:0 auto;">
        <table>
          <thead>
            <tr>
              <th>Feature</th>
              <th>Free</th>
              <th>Personal</th>
              <th>Professional</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Produkte in Bibliothek</td>
              <td>10</td><td>50</td><td>200</td>
            </tr>
            <tr>
              <td>Standard- & Mini-Layout</td>
              <td><span class="check">✓</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Browser-Extension (kostenlos)</td>
              <td><span class="check">✓</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Grid- / Listen-Layout</td>
              <td><span class="cross">✗</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Kategorien</td>
              <td><span class="cross">✗</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Automatische Preis-Updates</td>
              <td><span class="cross">✗</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Amazon-API-Sync</td>
              <td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Slider-Layout</td>
              <td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Vergleichstabelle</td>
              <td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Bulk-Import</td>
              <td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Prioritäts-Support</td>
              <td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Websites</td>
              <td>1</td><td>1</td><td>5</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" style="border-top:1px solid var(--color-border);" id="pricing">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Preise</span>
        <h2>Einfache, transparente Preise.</h2>
        <p>Kostenlos starten. Upgrade, wenn du bereit bist. Jederzeit kündbar.</p>
      </div>

      <!-- Billing toggle -->
      <div class="billing-toggle">
        <button class="billing-btn active" data-billing="monthly">Monatlich</button>
        <button class="billing-btn" data-billing="lifetime">Lifetime</button>
      </div>

      <!-- 3-card grid -->
      <div class="pricing-grid" id="pricing-grid">

        <!-- Free -->
        <div class="pricing-card">
          <div class="pricing-name">Free</div>
          <div>
            <div class="pricing-price">€0</div>
            <div class="pricing-desc" style="margin-top:.5rem;">Perfekt zum Ausprobieren.</div>
          </div>
          <ul class="pricing-features">
            <li>Bis zu 10 Produkte in der Bibliothek</li>
            <li>Standard- & Mini-Layout</li>
            <li>Amazon Tracking-ID</li>
            <li>Unbegrenzte Blöcke</li>
            <li>Browser-Extension (kostenlos)</li>
            <li class="no">Grid- / Listen-Layout</li>
            <li class="no">Automatische Preis-Updates</li>
            <li class="no">Amazon-API-Sync</li>
          </ul>
          <a href="https://wordpress.org/plugins/affiliate-blocks-for-amazon/" class="btn btn--outline" target="_blank" rel="noopener">
            Kostenlos herunterladen
          </a>
        </div>

        <!-- Personal -->
        <div class="pricing-card featured">
          <div class="pricing-name">Personal</div>
          <div>
            <div class="pricing-price">
              <span class="price-monthly">€3,99<span style="font-size:1rem;font-weight:400;color:var(--color-muted);"> / Monat</span></span>
              <span class="price-lifetime">€29,99<span style="font-size:1rem;font-weight:400;color:var(--color-muted);"> einmalig</span></span>
            </div>
            <div class="pricing-desc" style="margin-top:.5rem;">
              <span class="desc-monthly">Für Blogger — kein API-Zugang nötig.</span>
              <span class="desc-lifetime">Einmal zahlen, für immer nutzen. 1 Website.</span>
            </div>
          </div>
          <ul class="pricing-features">
            <li>Bis zu 50 Produkte in der Bibliothek</li>
            <li>Alle Layouts inkl. Grid & Liste</li>
            <li>Kategorien</li>
            <li>Automatische Preis-Updates</li>
            <li>1 Website-Lizenz</li>
            <li>Browser-Extension (kostenlos)</li>
            <li class="no">Amazon-API-Sync</li>
            <li class="no">Slider-Layout</li>
            <li class="no">Prioritäts-Support</li>
          </ul>
          <a href="#" class="btn btn--primary">
            <span class="cta-monthly">Personal holen</span>
            <span class="cta-lifetime">Lifetime holen</span>
          </a>
        </div>

        <!-- Professional -->
        <div class="pricing-card">
          <div class="pricing-name">Professional</div>
          <div>
            <div class="pricing-price">€9,99<span> / Monat</span></div>
            <div class="pricing-desc" style="margin-top:.5rem;">Mit Amazon-API-Zugang & mehr.</div>
          </div>
          <ul class="pricing-features">
            <li>Bis zu 200 Produkte in der Bibliothek</li>
            <li>Alle Layouts inkl. Slider</li>
            <li>Amazon-API-Sync</li>
            <li>Vergleichstabelle</li>
            <li>Bulk-Import</li>
            <li>Custom CSS pro Block</li>
            <li>Bis zu 5 Websites</li>
            <li>Prioritäts-Support</li>
            <li>Browser-Extension (kostenlos)</li>
          </ul>
          <a href="#" class="btn btn--outline">
            Professional holen
          </a>
        </div>

      </div>

      <!-- BMaC strip -->
      <div class="bmac-strip">
        <span class="bmac-icon">☕</span>
        <div class="bmac-content">
          <strong>Buy Me a Coffee Supporter</strong>
          <p>Unterstütze für 2,99€/Monat und erhalte kostenlosen Personal-Tier-Zugang — Grid-/Listen-Layout, Kategorien und bis zu 20 Produkte. Kein Lizenzschlüssel nötig.</p>
        </div>
        <a href="https://buymeacoffee.com/codeandblocks" class="btn btn--outline" target="_blank" rel="noopener" style="white-space:nowrap;">
          Jetzt Supporter werden →
        </a>
      </div>

      <p class="text-center" style="margin-top:1.5rem;color:var(--color-muted);font-size:.95rem;">
        Brauchst du mehr? Sonderwünsche? <a href="/de/kontakt">Schreib mir.</a>
      </p>

    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="border-top:1px solid var(--color-border);" id="faq">
    <div class="container">
      <div class="section-heading">
        <span class="badge">FAQ</span>
        <h2>Häufige Fragen</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section--sm" style="padding-bottom:5rem;">
    <div class="container">
      <div class="cta-banner">
        <h2>Bereit, deine Affiliate-Einnahmen zu steigern?</h2>
        <p>Fang kostenlos an und upgrade, wenn du bereit bist. Kein Risiko — 14 Tage Geld-zurück-Garantie.</p>
        <div class="hero-actions">
          <a href="#pricing" class="btn btn--primary btn--lg">Jetzt upgraden</a>
          <a
            href="https://wordpress.org/plugins/affiliate-blocks-for-amazon/"
            target="_blank"
            rel="noopener"
            class="btn btn--outline btn--lg"
          >
            Kostenlos starten ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    const btns = document.querySelectorAll('.billing-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const isLifetime = (btn as HTMLButtonElement).dataset.billing === 'lifetime';
        document.querySelectorAll('.price-monthly, .desc-monthly, .cta-monthly').forEach(el => {
          el.classList.toggle('is-hidden', isLifetime);
        });
        document.querySelectorAll('.price-lifetime, .desc-lifetime, .cta-lifetime').forEach(el => {
          el.classList.toggle('is-hidden', !isLifetime);
        });
      });
    });
  </script>

</Layout>
