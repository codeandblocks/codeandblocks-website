---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Danke — Code & Blocks"
  description="Nachricht erhalten."
  lang="de"
>
  <section class="hero" style="min-height:60vh;display:flex;align-items:center;">
    <div class="container" style="text-align:center;">
      <div style="font-size:3.5rem;margin-bottom:1.5rem;">✅</div>
      <h1 style="color:var(--color-white);font-size:clamp(1.8rem,4vw,2.4rem);font-weight:800;margin-bottom:1rem;">
        Nachricht erhalten!
      </h1>
      <p style="color:var(--color-muted);font-size:1.1rem;max-width:480px;margin:0 auto 2rem;">
        Danke fürs Schreiben. Ich melde mich normalerweise innerhalb von 24–48 Stunden.
      </p>
      <a href="/de/" class="btn btn--primary btn--lg">Zurück zur Startseite</a>
    </div>
  </section>
</Layout>
