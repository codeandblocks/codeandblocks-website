---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Impressum — Code & Blocks" canonical="/impressum">
  <section class="section">
    <div class="container" style="max-width:720px;">
      <h1 style="color:var(--color-white);font-size:2rem;margin-bottom:2rem;">Impressum</h1>
      <p class="text-muted">
        Angaben gemäß § 5 ECG (E-Commerce-Gesetz)
      </p>
      <div style="margin-top:2rem;display:flex;flex-direction:column;gap:1rem;">
        <div>
          <strong style="color:var(--color-white);">Inhaber</strong><br/>
          <span class="text-muted">Marijan Kelava</span>
        </div>
        <div>
          <strong style="color:var(--color-white);">Adresse</strong><br/>
          <span class="text-muted">Österreich</span>
        </div>
        <div>
          <strong style="color:var(--color-white);">E-Mail</strong><br/>
          <a href="mailto:marijan@kelava.at">marijan@kelava.at</a>
        </div>
        <div>
          <strong style="color:var(--color-white);">Website</strong><br/>
          <a href="https://codeandblocks.xyz">codeandblocks.xyz</a>
        </div>
      </div>
      <p class="text-muted" style="margin-top:2rem;font-size:.9rem;">
        <em>Bitte ergänze hier deine vollständige Adresse und ggf. UID-Nummer, bevor die Seite live geht.</em>
      </p>
    </div>
  </section>
</Layout>
