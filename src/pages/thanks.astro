---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Thank you — Code & Blocks"
  description="Message received."
  lang="en"
>
  <section class="hero" style="min-height:60vh;display:flex;align-items:center;">
    <div class="container" style="text-align:center;">
      <div style="font-size:3.5rem;margin-bottom:1.5rem;">✅</div>
      <h1 style="color:var(--color-white);font-size:clamp(1.8rem,4vw,2.4rem);font-weight:800;margin-bottom:1rem;">
        Message received!
      </h1>
      <p style="color:var(--color-muted);font-size:1.1rem;max-width:480px;margin:0 auto 2rem;">
        Thanks for reaching out. I'll get back to you within 24–48 hours.
      </p>
      <a href="/" class="btn btn--primary btn--lg">Back to home</a>
    </div>
  </section>
</Layout>
