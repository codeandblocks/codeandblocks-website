---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Datenschutz — Code & Blocks" canonical="/datenschutz">
  <section class="section">
    <div class="container" style="max-width:720px;">
      <h1 style="color:var(--color-white);font-size:2rem;margin-bottom:2rem;">Datenschutzerklärung</h1>
      <div style="display:flex;flex-direction:column;gap:1.5rem;color:var(--color-muted);line-height:1.8;">
        <div>
          <h2 style="color:var(--color-white);font-size:1.2rem;margin-bottom:.5rem;">Verantwortlicher</h2>
          <p>Marijan Kelava · <a href="mailto:marijan@codeandblocks.xyz">marijan@codeandblocks.xyz</a></p>
        </div>
        <div>
          <h2 style="color:var(--color-white);font-size:1.2rem;margin-bottom:.5rem;">Hosting</h2>
          <p>
            Diese Website wird über Netlify gehostet (Netlify, Inc., 44 Montgomery Street, Suite 300, San Francisco, CA 94104, USA).
            Beim Aufruf der Website werden von Netlify automatisch Server-Logfiles gespeichert (IP-Adresse, Browser, Datum/Uhrzeit).
            Weitere Informationen: <a href="https://www.netlify.com/privacy/" target="_blank" rel="noopener">netlify.com/privacy</a>
          </p>
        </div>
        <div>
          <h2 style="color:var(--color-white);font-size:1.2rem;margin-bottom:.5rem;">Externe Links & Fonts</h2>
          <p>
            Diese Seite nutzt Google Fonts (fonts.googleapis.com). Dabei wird deine IP-Adresse an Google übertragen.
            Weitere Informationen: <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">policies.google.com/privacy</a>
          </p>
        </div>
        <div>
          <h2 style="color:var(--color-white);font-size:1.2rem;margin-bottom:.5rem;">Keine Cookies / kein Tracking</h2>
          <p>
            Diese Website setzt keine eigenen Cookies und verwendet kein Analytics-Tracking.
          </p>
        </div>
        <div>
          <h2 style="color:var(--color-white);font-size:1.2rem;margin-bottom:.5rem;">Kontakt</h2>
          <p>
            Bei Datenschutzfragen wende dich an: <a href="mailto:marijan@codeandblocks.xyz">marijan@codeandblocks.xyz</a>
          </p>
        </div>
        <p style="font-size:.85rem;">
          <em>Stand: März 2026 · Diese Datenschutzerklärung sollte vor dem Go-live von einem Rechtsanwalt geprüft werden.</em>
        </p>
      </div>
    </div>
  </section>
</Layout>
