---
import Layout from '../layouts/Layout.astro';

const pricingPlans = [
  {
    name: 'Free',
    price: '0',
    period: '',
    desc: 'Perfect for getting started.',
    features: [
      { text: '1 block style (Standard)', included: true },
      { text: 'Amazon link with tracking ID', included: true },
      { text: 'Unlimited blocks', included: true },
      { text: 'WordPress.org support', included: true },
      { text: 'All block styles', included: false },
      { text: 'Compact style', included: false },
      { text: 'Comparison table block', included: false },
      { text: 'Priority support', included: false },
    ],
    cta: 'Download for free',
    ctaUrl: 'https://wordpress.org/plugins/affiliate-blocks-for-amazon/',
    ctaClass: 'btn--outline',
    featured: false,
  },
  {
    name: 'Personal',
    price: '29',
    period: 'one-time',
    desc: 'For 1 website — everything you need.',
    features: [
      { text: 'All block styles', included: true },
      { text: 'Compact style', included: true },
      { text: 'Comparison table block', included: true },
      { text: 'Priority support', included: true },
      { text: '1 site license', included: true },
      { text: 'Lifetime updates', included: true },
      { text: 'Multiple websites', included: false },
      { text: 'Agency use', included: false },
    ],
    cta: 'Get Personal',
    ctaUrl: '#',
    ctaClass: 'btn--primary',
    featured: true,
  },
  {
    name: 'Business',
    price: '59',
    period: 'one-time',
    desc: 'For up to 5 websites.',
    features: [
      { text: 'All block styles', included: true },
      { text: 'Compact style', included: true },
      { text: 'Comparison table block', included: true },
      { text: 'Priority support', included: true },
      { text: 'Up to 5 sites', included: true },
      { text: 'Lifetime updates', included: true },
      { text: 'Agency use', included: false },
      { text: 'Unlimited websites', included: false },
    ],
    cta: 'Get Business',
    ctaUrl: '#',
    ctaClass: 'btn--outline',
    featured: false,
  },
  {
    name: 'Agency',
    price: '129',
    period: 'one-time',
    desc: 'For agencies & unlimited websites.',
    features: [
      { text: 'All block styles', included: true },
      { text: 'Compact style', included: true },
      { text: 'Comparison table block', included: true },
      { text: 'Priority support', included: true },
      { text: 'Unlimited websites', included: true },
      { text: 'Lifetime updates', included: true },
      { text: 'Agency use', included: true },
      { text: 'White-label', included: false },
    ],
    cta: 'Get Agency',
    ctaUrl: '#',
    ctaClass: 'btn--outline',
    featured: false,
  },
];

const faqs = [
  {
    q: 'Does this plugin work with every WordPress theme?',
    a: 'Yes. Affiliate Blocks for Amazon is theme-independent and works with any modern WordPress theme that supports the Gutenberg editor.',
  },
  {
    q: 'What happens after purchase?',
    a: 'You will instantly receive an email with your license key. Enter it once in the WordPress admin area — all Pro features will be unlocked immediately and you will receive automatic updates.',
  },
  {
    q: 'Can I try Pro before buying?',
    a: 'The free version is always available on WordPress.org. After purchase, you have 14 days to test the Pro features — if you are not satisfied, you will receive a full refund.',
  },
  {
    q: 'What is the difference between the license tiers?',
    a: 'The only difference is the number of websites you can use the plugin on. Features and support are identical across Personal, Business, and Agency.',
  },
  {
    q: 'I am a Buy Me a Coffee supporter. Do I get Pro access?',
    a: 'Yes! Active BMaC supporters get free Pro access. Simply enter your BMaC email address on the plugin settings page.',
  },
  {
    q: 'Are there any recurring costs?',
    a: 'No. You pay once and receive lifetime updates for the version you purchased.',
  },
];
---

<Layout
  title="Affiliate Blocks for Amazon — Beautiful Product Boxes for Gutenberg"
  description="Create stunning Amazon product boxes directly in the Gutenberg editor. No shortcode, no page builder. Free to start, Pro from €29."
  canonical="/affiliateblocks"
  lang="en"
  altHref="/de/affiliateblocks"
>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="badge">WordPress Plugin · Free to start</span>
      <h1>Amazon product boxes<br/>that actually <em>convert.</em></h1>
      <p>
        Create professional product boxes directly in the Gutenberg editor —
        no shortcodes, no page builders, no compromises.
      </p>
      <div class="hero-actions">
        <a href="#pricing" class="btn btn--primary btn--lg">Pro from €29 →</a>
        <a
          href="https://wordpress.org/plugins/affiliate-blocks-for-amazon/"
          target="_blank"
          rel="noopener"
          class="btn btn--outline btn--lg"
        >
          Try for free ↗
        </a>
      </div>
      <p style="margin-top:1.5rem;font-size:.875rem;color:var(--color-muted);">
        ★★★★★ · Active on 1,000+ websites
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="section" style="border-top:1px solid var(--color-border);" id="features">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Features</span>
        <h2>Everything you need</h2>
        <p>Focused features for affiliate marketers — no unnecessary overhead.</p>
      </div>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🧱</div>
          <h3>Native Gutenberg Block</h3>
          <p>No shortcode, no plugin overhead. Just insert the block and configure it.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎨</div>
          <h3>Multiple Block Styles</h3>
          <p>Standard, Compact, and more — choose the style that fits your website.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔗</div>
          <h3>Tracking ID Integration</h3>
          <p>Your Amazon tracking ID is automatically appended to all links. Set it once, done.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Fast & Lightweight</h3>
          <p>No jQuery, no bloated CSS. The plugin only loads what is actually needed.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Comparison Table Block</h3>
          <p>Compare multiple products in a clean table — perfect for review articles. <span style="color:var(--color-accent);font-size:.8rem;font-weight:600;">PRO</span></p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔄</div>
          <h3>Automatic Updates</h3>
          <p>Updates are delivered directly through WordPress — no manual downloading required.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Free vs Pro -->
  <section class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Comparison</span>
        <h2>Free vs. Pro</h2>
      </div>
      <div class="comparison" style="max-width:700px;margin:0 auto;">
        <table>
          <thead>
            <tr>
              <th>Feature</th>
              <th>Free</th>
              <th>Pro</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Standard product box</td>
              <td><span class="check">✓</span></td>
              <td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Amazon tracking ID</td>
              <td><span class="check">✓</span></td>
              <td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Unlimited blocks</td>
              <td><span class="check">✓</span></td>
              <td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>All block styles</td>
              <td><span class="cross">✗</span></td>
              <td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Compact style</td>
              <td><span class="cross">✗</span></td>
              <td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Comparison table block</td>
              <td><span class="cross">✗</span></td>
              <td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Automatic plugin updates</td>
              <td><span class="cross">✗</span></td>
              <td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Priority support</td>
              <td><span class="cross">✗</span></td>
              <td><span class="check">✓</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" style="border-top:1px solid var(--color-border);" id="pricing">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Pricing</span>
        <h2>One-time price. Lifetime updates.</h2>
        <p>No subscription. No monthly stress. Pay once and use the plugin forever.</p>
      </div>

      <div class="pricing-grid">
        {pricingPlans.map((plan) => (
          <div class={`pricing-card ${plan.featured ? 'featured' : ''}`}>
            <div class="pricing-name">{plan.name}</div>
            <div>
              <div class="pricing-price">
                €{plan.price}
                {plan.period && <span> / {plan.period}</span>}
              </div>
              <div class="pricing-desc" style="margin-top:.5rem;">{plan.desc}</div>
            </div>
            <ul class="pricing-features">
              {plan.features.map((f) => (
                <li class={f.included ? '' : 'no'}>{f.text}</li>
              ))}
            </ul>
            <a
              href={plan.ctaUrl}
              class={`btn ${plan.ctaClass}`}
              target={plan.ctaUrl.startsWith('http') ? '_blank' : undefined}
              rel={plan.ctaUrl.startsWith('http') ? 'noopener' : undefined}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>

      <p class="text-center text-muted" style="margin-top:2rem;font-size:.9rem;">
        ☕ <strong style="color:var(--color-text);">Buy Me a Coffee supporters</strong> get free Pro access.
        <a href="https://buymeacoffee.com/codeandblocks">Become a supporter →</a>
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="border-top:1px solid var(--color-border);" id="faq">
    <div class="container">
      <div class="section-heading">
        <span class="badge">FAQ</span>
        <h2>Frequently Asked Questions</h2>
      </div>

      <div class="faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section--sm" style="padding-bottom:5rem;">
    <div class="container">
      <div class="cta-banner">
        <h2>Ready to boost your affiliate revenue?</h2>
        <p>
          Start for free and upgrade when you are ready. No risk — 14-day money-back guarantee.
        </p>
        <div class="hero-actions">
          <a href="#pricing" class="btn btn--primary btn--lg">Upgrade now</a>
          <a
            href="https://wordpress.org/plugins/affiliate-blocks-for-amazon/"
            target="_blank"
            rel="noopener"
            class="btn btn--outline btn--lg"
          >
            Start for free ↗
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
