---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: 'Does this plugin work with every WordPress theme?',
    a: 'Yes. Affiliate Blocks for Amazon is theme-independent and works with any modern WordPress theme that supports the Gutenberg editor.',
  },
  {
    q: 'What happens after purchase?',
    a: 'You will instantly receive an email with your license key. Enter it once in the WordPress admin area — all Pro features will be unlocked immediately and you will receive automatic updates.',
  },
  {
    q: 'Can I try Pro before buying?',
    a: 'The free version is always available on WordPress.org. After purchase, you have 14 days to test the Pro features — if you are not satisfied, you will receive a full refund.',
  },
  {
    q: 'What is the difference between Personal and Professional?',
    a: 'Personal is designed for bloggers without Amazon API access — you manage your product library via the browser extension. Professional adds direct Amazon API sync, so products import automatically into your dashboard. It also includes the slider layout, comparison table, bulk import, custom CSS per block, and up to 5 websites.',
  },
  {
    q: 'Do I need the browser extension?',
    a: 'Yes — a free Chrome and Firefox extension is required to import products into your library. It works across all plans and is completely free. (Currently in development.)',
  },
  {
    q: 'I am a Buy Me a Coffee supporter. Do I get Pro access?',
    a: 'Yes! Active BMaC supporters (€2.99/month) get Supporter-tier access for free — that includes grid/list layouts, categories, and up to 20 products in the library. Simply enter your BMaC email address on the plugin settings page.',
  },
  {
    q: 'Are there any recurring costs?',
    a: 'Personal is available as a monthly subscription (€3.99/month, cancel anytime) or as a one-time Lifetime purchase (€29.99). Professional is a monthly subscription (€9.99/month, cancel anytime). If you prefer to pay once, the Lifetime plan gives you Personal-level features forever.',
  },
];
---

<Layout
  title="Affiliate Blocks for Amazon — Beautiful Product Boxes for Gutenberg"
  description="Create stunning Amazon product boxes directly in the Gutenberg editor. No shortcode, no page builder. Free to start, Pro from €3.99/month."
  canonical="/affiliateblocks"
  lang="en"
  altHref="/de/affiliateblocks"
>

<style>
  /* Override featured badge text for EN */
  .pricing-card.featured::before { content: 'Popular'; }

  /* Equal-height cards */
  #pricing-grid { align-items: stretch; }

  /* Billing toggle */
  .billing-toggle {
    display: flex;
    margin: 0 auto 2.5rem;
    width: fit-content;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 50px;
    padding: 4px;
  }
  .billing-btn {
    background: none;
    border: none;
    padding: .45rem 1.4rem;
    border-radius: 50px;
    font-size: .9rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--color-muted);
    transition: all .2s;
    font-family: var(--font);
  }
  .billing-btn.active {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .is-hidden { display: none !important; }

  /* Responsive pricing grid */
  #pricing-grid {
    max-width: 900px;
    margin: 0 auto;
    grid-template-columns: repeat(3, 1fr);
  }
  @media (max-width: 700px) {
    #pricing-grid { grid-template-columns: 1fr; }
  }

  /* BMaC strip */
  .bmac-strip {
    max-width: 900px;
    margin: 2rem auto 0;
    background: rgba(245,158,11,.07);
    border: 1px solid rgba(245,158,11,.2);
    border-radius: var(--radius-lg);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .bmac-icon { font-size: 2rem; flex-shrink: 0; }
  .bmac-content { flex: 1; min-width: 200px; }
  .bmac-content strong { color: var(--color-white); display: block; margin-bottom: .25rem; }
  .bmac-content p { color: var(--color-muted); font-size: .9rem; margin: 0; }
</style>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="badge">WordPress Plugin · Free to start</span>
      <h1>Amazon product boxes<br/>that actually <em>convert.</em></h1>
      <p>
        Create professional product boxes directly in the Gutenberg editor —
        no shortcodes, no page builders, no compromises.
      </p>
      <div class="hero-actions">
        <a href="#pricing" class="btn btn--primary btn--lg">Pro from €3.99/month →</a>
        <a
          href="https://wordpress.org/plugins/affiliate-blocks-for-amazon/"
          target="_blank"
          rel="noopener"
          class="btn btn--outline btn--lg"
        >
          Try for free ↗
        </a>
      </div>
      <p style="margin-top:1.5rem;font-size:.875rem;color:var(--color-muted);">
        ★★★★★ · Active on 1,000+ websites
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="section" style="border-top:1px solid var(--color-border);" id="features">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Features</span>
        <h2>Everything you need</h2>
        <p>Focused features for affiliate marketers — no unnecessary overhead.</p>
      </div>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🧱</div>
          <h3>Native Gutenberg Block</h3>
          <p>No shortcode, no plugin overhead. Just insert the block and configure it.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎨</div>
          <h3>Multiple Block Styles</h3>
          <p>Standard, Compact, and more — choose the style that fits your website.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔗</div>
          <h3>Tracking ID Integration</h3>
          <p>Your Amazon tracking ID is automatically appended to all links. Set it once, done.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Fast & Lightweight</h3>
          <p>No jQuery, no bloated CSS. The plugin only loads what is actually needed.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Comparison Table Block</h3>
          <p>Compare multiple products in a clean table — perfect for review articles. <span style="color:var(--color-accent);font-size:.8rem;font-weight:600;">PRO</span></p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔌</div>
          <h3>Browser Extension</h3>
          <p>Free Chrome & Firefox extension to import products directly from Amazon — required for all plans. <span style="color:var(--color-muted);font-size:.8rem;">(Coming soon)</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Free vs Pro -->
  <section class="section" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Comparison</span>
        <h2>Free vs. Pro</h2>
      </div>
      <div class="comparison" style="max-width:760px;margin:0 auto;">
        <table>
          <thead>
            <tr>
              <th>Feature</th>
              <th>Free</th>
              <th>Personal</th>
              <th>Professional</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Products in library</td>
              <td>10</td><td>50</td><td>200</td>
            </tr>
            <tr>
              <td>Standard & mini layout</td>
              <td><span class="check">✓</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Browser extension (free)</td>
              <td><span class="check">✓</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Grid / list layout</td>
              <td><span class="cross">✗</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Categories</td>
              <td><span class="cross">✗</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Automatic price updates</td>
              <td><span class="cross">✗</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Amazon API sync</td>
              <td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Slider layout</td>
              <td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Comparison table</td>
              <td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Bulk import</td>
              <td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Priority support</td>
              <td><span class="cross">✗</span></td><td><span class="cross">✗</span></td><td><span class="check">✓</span></td>
            </tr>
            <tr>
              <td>Websites</td>
              <td>1</td><td>1</td><td>5</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" style="border-top:1px solid var(--color-border);" id="pricing">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Pricing</span>
        <h2>Simple, transparent pricing.</h2>
        <p>Start free. Upgrade when you're ready. Cancel anytime.</p>
      </div>

      <!-- Billing toggle -->
      <div class="billing-toggle">
        <button class="billing-btn active" data-billing="monthly">Monthly</button>
        <button class="billing-btn" data-billing="lifetime">Lifetime</button>
      </div>

      <!-- 3-card grid -->
      <div class="pricing-grid" id="pricing-grid">

        <!-- Free -->
        <div class="pricing-card">
          <div class="pricing-name">Free</div>
          <div>
            <div class="pricing-price">€0</div>
            <div class="pricing-desc" style="margin-top:.5rem;">Perfect for getting started.</div>
          </div>
          <ul class="pricing-features">
            <li>Up to 10 products in library</li>
            <li>Standard & mini layout</li>
            <li>Amazon tracking ID</li>
            <li>Unlimited blocks</li>
            <li>Browser extension (free)</li>
            <li class="no">Grid / list layout</li>
            <li class="no">Automatic price updates</li>
            <li class="no">Amazon API sync</li>
          </ul>
          <a href="https://wordpress.org/plugins/affiliate-blocks-for-amazon/" class="btn btn--outline" target="_blank" rel="noopener">
            Download for free
          </a>
        </div>

        <!-- Personal -->
        <div class="pricing-card featured">
          <div class="pricing-name">Personal</div>
          <div class="price-monthly">
            <div class="pricing-price">€3.99<span> / month</span></div>
            <div class="pricing-desc" style="margin-top:.5rem;">For bloggers — no API access needed.</div>
          </div>
          <div class="price-lifetime is-hidden">
            <div class="pricing-price">€29.99<span> one-time</span></div>
            <div class="pricing-desc" style="margin-top:.5rem;">Pay once, use forever. 1 website.</div>
          </div>
          <ul class="pricing-features">
            <li>Up to 50 products in library</li>
            <li>All layouts incl. grid & list</li>
            <li>Categories</li>
            <li>Automatic price updates</li>
            <li>1 site license</li>
            <li>Browser extension (free)</li>
            <li class="no">Amazon API sync</li>
            <li class="no">Slider layout</li>
            <li class="no">Priority support</li>
          </ul>
          <a href="#" class="btn btn--primary cta-monthly">Get Personal</a>
          <a href="#" class="btn btn--primary cta-lifetime is-hidden">Get Lifetime</a>
        </div>

        <!-- Professional -->
        <div class="pricing-card">
          <div class="pricing-name">Professional</div>
          <div>
            <div class="pricing-price">€9.99<span> / month</span></div>
            <div class="pricing-desc" style="margin-top:.5rem;">With Amazon API access & more.</div>
          </div>
          <ul class="pricing-features">
            <li>Up to 200 products in library</li>
            <li>All layouts incl. slider</li>
            <li>Amazon API sync</li>
            <li>Comparison table</li>
            <li>Bulk import</li>
            <li>Custom CSS per block</li>
            <li>Up to 5 websites</li>
            <li>Priority support</li>
            <li>Browser extension (free)</li>
          </ul>
          <a href="#" class="btn btn--outline">
            Get Professional
          </a>
        </div>

      </div>

      <!-- BMaC strip -->
      <div class="bmac-strip">
        <span class="bmac-icon">☕</span>
        <div class="bmac-content">
          <strong>Buy Me a Coffee Supporter</strong>
          <p>Support for €2.99/month and get Personal-tier access for free — grid/list layouts, categories, and up to 20 products. No license key needed.</p>
        </div>
        <a href="https://buymeacoffee.com/codeandblocks" class="btn btn--outline" target="_blank" rel="noopener" style="white-space:nowrap;">
          Become a supporter →
        </a>
      </div>

      <p class="text-center" style="margin-top:1.5rem;color:var(--color-muted);font-size:.95rem;">
        Need more? Need personalization? <a href="/contact">Let's talk.</a>
      </p>

    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="border-top:1px solid var(--color-border);" id="faq">
    <div class="container">
      <div class="section-heading">
        <span class="badge">FAQ</span>
        <h2>Frequently Asked Questions</h2>
      </div>

      <div class="faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section--sm" style="padding-bottom:5rem;">
    <div class="container">
      <div class="cta-banner">
        <h2>Ready to boost your affiliate revenue?</h2>
        <p>
          Start for free and upgrade when you are ready. No risk — 14-day money-back guarantee.
        </p>
        <div class="hero-actions">
          <a href="#pricing" class="btn btn--primary btn--lg">Upgrade now</a>
          <a
            href="https://wordpress.org/plugins/affiliate-blocks-for-amazon/"
            target="_blank"
            rel="noopener"
            class="btn btn--outline btn--lg"
          >
            Start for free ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    const btns = document.querySelectorAll('.billing-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const isLifetime = (btn as HTMLButtonElement).dataset.billing === 'lifetime';
        document.querySelectorAll('.price-monthly, .cta-monthly').forEach(el => {
          el.classList.toggle('is-hidden', isLifetime);
        });
        document.querySelectorAll('.price-lifetime, .cta-lifetime').forEach(el => {
          el.classList.toggle('is-hidden', !isLifetime);
        });
      });
    });
  </script>

</Layout>
