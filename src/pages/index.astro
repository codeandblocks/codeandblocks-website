---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Code & Blocks — WordPress Plugins by Marijan Kelava"
  description="Lean, focused WordPress Gutenberg plugins for bloggers, affiliate marketers, and content creators."
  canonical="/"
  lang="en"
  altHref="/de/"
>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="badge">WordPress Plugins</span>
      <h1>Plugins that actually<br/><em>simplify your workflow.</em></h1>
      <p>
        I build focused WordPress plugins for bloggers, affiliate marketers,
        and content creators — lean, fast, and without unnecessary bloat.
      </p>
      <div class="hero-actions">
        <a href="#plugins" class="btn btn--primary btn--lg">Discover Plugins</a>
        <a href="#about" class="btn btn--outline btn--lg">About me</a>
      </div>
    </div>
  </section>

  <!-- Plugins -->
  <section class="section" id="plugins">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Products</span>
        <h2>My Plugins</h2>
        <p>Each plugin solves one specific problem — nothing more, nothing less.</p>
      </div>

      <a href="/affiliateblocks" class="plugin-card" style="max-width:780px;margin:0 auto;">
        <div class="plugin-card-icon">🛍️</div>
        <div>
          <h3>Affiliate Blocks for Amazon</h3>
          <p>
            Beautiful, conversion-optimized product boxes for Amazon affiliates —
            directly in the Gutenberg Editor. No shortcode, no page builder needed.
          </p>
          <div class="plugin-card-tags">
            <span class="tag">Gutenberg</span>
            <span class="tag">Amazon Affiliate</span>
            <span class="tag">WordPress</span>
            <span class="tag">Free to start</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- About -->
  <section class="section" id="about" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2>Hi, I'm Marijan.</h2>
          <p>
            I build WordPress plugins I'd actually want to use myself.
            My focus is on clean code, good UX, and real value —
            without feature bloat.
          </p>
          <p>
            If you have questions, want to leave feedback, or are interested
            in a custom project, feel free to reach out.
          </p>
          <a href="/contact" class="btn btn--outline" style="margin-top:.5rem;">
            Get in touch
          </a>
        </div>
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:2rem;display:flex;flex-direction:column;gap:1.25rem;">
          <div style="display:flex;align-items:center;gap:1rem;">
            <span style="font-size:2rem;">🇦🇹</span>
            <div>
              <div style="color:var(--color-white);font-weight:600;">Austria-based</div>
              <div style="color:var(--color-muted);font-size:.875rem;">Vienna, Austria</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:1rem;">
            <span style="font-size:2rem;">⚡</span>
            <div>
              <div style="color:var(--color-white);font-weight:600;">Fast responses</div>
              <div style="color:var(--color-muted);font-size:.875rem;">Typically within 24–48h</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:1rem;">
            <span style="font-size:2rem;">🛠️</span>
            <div>
              <div style="color:var(--color-white);font-weight:600;">Actively maintained</div>
              <div style="color:var(--color-muted);font-size:.875rem;">Regular updates & support</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section--sm">
    <div class="container">
      <div class="cta-banner">
        <h2>Ready to get started?</h2>
        <p>Try Affiliate Blocks for Amazon for free — no account needed.</p>
        <div class="hero-actions">
          <a href="/affiliateblocks" class="btn btn--primary btn--lg">View the Plugin</a>
          <a href="https://wordpress.org/plugins/affiliate-blocks-for-amazon/" target="_blank" rel="noopener" class="btn btn--outline btn--lg">
            WordPress.org ↗
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
