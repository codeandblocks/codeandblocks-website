---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Code & Blocks — WordPress Plugins von Marijan Kelava"
  description="Hochwertige WordPress Gutenberg Blocks und Plugins für Blogger, Affiliate-Marketer und Entwickler."
  canonical="/"
>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="badge">WordPress Plugins</span>
      <h1>Plugins, die <em>deinen Workflow</em><br/>wirklich vereinfachen.</h1>
      <p>
        Ich baue fokussierte WordPress Plugins für Blogger, Affiliate-Marketer
        und Content Creator — schlank, schnell und ohne unnötigen Ballast.
      </p>
      <div class="hero-actions">
        <a href="#plugins" class="btn btn--primary btn--lg">Plugins entdecken</a>
        <a href="#about" class="btn btn--outline btn--lg">Über mich</a>
      </div>
    </div>
  </section>

  <!-- Plugins -->
  <section class="section" id="plugins">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Produkte</span>
        <h2>Meine Plugins</h2>
        <p>Jedes Plugin löst ein konkretes Problem — nichts mehr, nichts weniger.</p>
      </div>

      <a href="/affiliateblocks" class="plugin-card" style="max-width:780px;margin:0 auto;">
        <div class="plugin-card-icon">🛍️</div>
        <div>
          <h3>Affiliate Blocks for Amazon</h3>
          <p>
            Schöne, conversion-optimierte Produktboxen für Amazon-Affiliates —
            direkt im Gutenberg Editor. Kein Shortcode, kein Pagebuilder nötig.
          </p>
          <div class="plugin-card-tags">
            <span class="tag">Gutenberg</span>
            <span class="tag">Amazon Affiliate</span>
            <span class="tag">WordPress</span>
            <span class="tag">Kostenlos verfügbar</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- About -->
  <section class="section" id="about" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2>Hi, ich bin Marijan.</h2>
          <p>
            Ich entwickle WordPress Plugins, die ich selbst gerne nutzen würde.
            Mein Fokus liegt auf sauberem Code, guter UX und echtem Mehrwert —
            ohne Feature-Bloat.
          </p>
          <p>
            Wenn du Fragen hast, Feedback loswerden möchtest oder an einem
            Custom-Projekt interessiert bist, schreib mich gerne an.
          </p>
          <a href="mailto:marijan@kelava.at" class="btn btn--outline" style="margin-top:.5rem;">
            Kontakt aufnehmen
          </a>
        </div>
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:2rem;display:flex;flex-direction:column;gap:1.25rem;">
          <div style="display:flex;align-items:center;gap:1rem;">
            <span style="font-size:2rem;">🇦🇹</span>
            <div>
              <div style="color:var(--color-white);font-weight:600;">Österreich-basiert</div>
              <div style="color:var(--color-muted);font-size:.875rem;">Wien, Österreich</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:1rem;">
            <span style="font-size:2rem;">⚡</span>
            <div>
              <div style="color:var(--color-white);font-weight:600;">Schnelle Antworten</div>
              <div style="color:var(--color-muted);font-size:.875rem;">Typisch innerhalb 24–48h</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:1rem;">
            <span style="font-size:2rem;">🛠️</span>
            <div>
              <div style="color:var(--color-white);font-weight:600;">Aktive Entwicklung</div>
              <div style="color:var(--color-muted);font-size:.875rem;">Regelmäßige Updates & Support</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section--sm">
    <div class="container">
      <div class="cta-banner">
        <h2>Bereit loszulegen?</h2>
        <p>Probiere Affiliate Blocks for Amazon kostenlos aus — kein Konto nötig.</p>
        <div class="hero-actions">
          <a href="/affiliateblocks" class="btn btn--primary btn--lg">Zum Plugin</a>
          <a href="https://wordpress.org/plugins/affiliate-blocks-for-amazon/" target="_blank" rel="noopener" class="btn btn--outline btn--lg">
            WordPress.org ↗
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
