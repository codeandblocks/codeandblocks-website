---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Code & Blocks — Digital Products by Marijan Kelava"
  description="I design and build digital products — web apps, tools, and WordPress plugins. Based in Austria."
  canonical="/"
  lang="en"
  altHref="/de/"
>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="badge">Indie Developer · Vienna, Austria</span>
      <h1>I build things<br/>for the <em>web.</em></h1>
      <p>
        Apps, tools, WordPress plugins — I design and build focused digital products
        that solve real problems. Clean code, good UX, no unnecessary complexity.
      </p>
      <div class="hero-actions">
        <a href="#projects" class="btn btn--primary btn--lg">See my work</a>
        <a href="#about" class="btn btn--outline btn--lg">About me</a>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="section" id="projects">
    <div class="container">
      <div class="section-heading">
        <span class="badge">Projects</span>
        <h2>What I've built</h2>
        <p>Each project solves a specific problem — nothing more, nothing less.</p>
      </div>

      <div style="max-width:780px;margin:0 auto;display:flex;flex-direction:column;gap:1.25rem;">
        <a href="/affiliateblocks" class="plugin-card">
          <div class="plugin-card-icon">🛍️</div>
          <div>
            <h3>Affiliate Blocks for Amazon</h3>
            <p>
              Beautiful, conversion-optimized product boxes for Amazon affiliates —
              directly in the Gutenberg Editor. No shortcode, no page builder needed.
            </p>
            <div class="plugin-card-tags">
              <span class="tag">WordPress Plugin</span>
              <span class="tag">Gutenberg</span>
              <span class="tag">Amazon Affiliate</span>
              <span class="tag">Free to start</span>
            </div>
          </div>
        </a>

        <!-- Placeholder for future projects -->
        <div class="plugin-card" style="opacity:.45;cursor:default;pointer-events:none;">
          <div class="plugin-card-icon">🔧</div>
          <div>
            <h3>More coming soon</h3>
            <p>
              New tools and projects are in the works. Follow along or
              <a href="/contact" style="pointer-events:all;opacity:1;">get in touch</a> if you have an idea.
            </p>
            <div class="plugin-card-tags">
              <span class="tag">In progress</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section" id="about" style="border-top:1px solid var(--color-border);">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2>Hi, I'm Marijan.</h2>
          <p>
            I'm an indie developer based in Vienna, Austria. I build digital products —
            mainly web tools and WordPress plugins — that I'd actually want to use myself.
          </p>
          <p>
            My focus is on clean code, good UX, and shipping things that work.
            If you have a project idea, need a custom solution, or just want to say hi —
            feel free to reach out.
          </p>
          <a href="/contact" class="btn btn--outline" style="margin-top:.5rem;">
            Get in touch
          </a>
        </div>
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:2rem;display:flex;flex-direction:column;gap:1.25rem;">
          <div style="display:flex;align-items:center;gap:1rem;">
            <span style="font-size:2rem;">🇦🇹</span>
            <div>
              <div style="color:var(--color-white);font-weight:600;">Austria-based</div>
              <div style="color:var(--color-muted);font-size:.875rem;">Vienna, Austria</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:1rem;">
            <span style="font-size:2rem;">⚡</span>
            <div>
              <div style="color:var(--color-white);font-weight:600;">Fast responses</div>
              <div style="color:var(--color-muted);font-size:.875rem;">Typically within 24–48h</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:1rem;">
            <span style="font-size:2rem;">🛠️</span>
            <div>
              <div style="color:var(--color-white);font-weight:600;">Actively building</div>
              <div style="color:var(--color-muted);font-size:.875rem;">Regular updates & new projects</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section--sm">
    <div class="container">
      <div class="cta-banner">
        <h2>Got a project in mind?</h2>
        <p>Whether it's a custom tool, a WordPress plugin, or something else entirely — let's talk.</p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn--primary btn--lg">Get in touch</a>
          <a href="#projects" class="btn btn--outline btn--lg">See my work</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
