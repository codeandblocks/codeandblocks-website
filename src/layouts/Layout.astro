---
interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  canonical?: string;
  lang?: 'en' | 'de';
  altHref?: string; // href for the other language
}

const {
  title,
  description = 'WordPress Plugins by Marijan Kelava — Code & Blocks',
  ogTitle,
  canonical,
  lang = 'en',
  altHref,
} = Astro.props;

const siteUrl = 'https://codeandblocks.xyz';
const currentPath = Astro.url.pathname;

const isDE = lang === 'de';
const nav = {
  plugins: isDE ? 'Plugins'       : 'Plugins',
  about:   isDE ? 'Über mich'     : 'About',
  plugin:  isDE ? 'Affiliate Blocks' : 'Affiliate Blocks',
  buy:     isDE ? 'Jetzt kaufen'  : 'Buy now',
};
const homeHref        = isDE ? '/de/'               : '/';
const pluginsHref     = isDE ? '/de/#plugins'       : '/#plugins';
const aboutHref       = isDE ? '/de/#about'         : '/#about';
const affiliateHref   = isDE ? '/de/affiliateblocks': '/affiliateblocks';
const pricingHref     = isDE ? '/de/affiliateblocks#pricing' : '/affiliateblocks#pricing';
const impressumHref   = '/impressum';
const datenschutzHref = '/datenschutz';
const footerCopy      = isDE
  ? `© ${new Date().getFullYear()} Marijan Kelava · codeandblocks.xyz`
  : `© ${new Date().getFullYear()} Marijan Kelava · codeandblocks.xyz`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={siteUrl + canonical} />}
    {altHref && lang === 'en' && <link rel="alternate" hreflang="de" href={siteUrl + altHref} />}
    {altHref && lang === 'de' && <link rel="alternate" hreflang="en" href={siteUrl + altHref} />}

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={ogTitle ?? title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={siteUrl + currentPath} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <a href={homeHref} class="site-logo">
          ⬡ Code &amp; <span>Blocks</span>
        </a>
        <nav class="site-nav">
          <a href={pluginsHref}>{nav.plugins}</a>
          <a href={aboutHref}>{nav.about}</a>
          <a href={affiliateHref}>{nav.plugin}</a>
          {altHref && (
            <a href={altHref} class="lang-switcher" title={isDE ? 'English' : 'Deutsch'}>
              {isDE ? '🇬🇧 EN' : '🇦🇹 DE'}
            </a>
          )}
          <a href={pricingHref} class="btn btn--primary" style="padding:.5rem 1.1rem;font-size:.9rem;">{nav.buy}</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>{footerCopy}</p>
        <p>
          <a href={impressumHref}>Impressum</a> ·
          <a href={datenschutzHref}>Datenschutz</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  .lang-switcher {
    font-size: .85rem;
    font-weight: 600;
    color: var(--color-muted) !important;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: .25rem .6rem;
    transition: border-color .2s, color .2s;
  }
  .lang-switcher:hover {
    border-color: var(--color-accent);
    color: var(--color-accent) !important;
    text-decoration: none;
  }
</style>
